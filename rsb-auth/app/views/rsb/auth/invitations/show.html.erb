<%# Invitation acceptance page — shown when a user follows an invitation link.
    By default the InvitationsController redirects straight to the registration
    page.  Export this view with `rails g rsb:auth:views --only invitations` and
    override InvitationsController#show to render it if you want a dedicated
    landing page instead. %>

<div class="rsb-auth-card">
  <h1 class="rsb-auth-heading">You've been invited!</h1>

  <p class="rsb-auth-subtext">Create your account to get started.</p>

  <%= link_to 'Create Account', new_registration_path(invite_token: params[:token]),
              class: 'rsb-auth-btn rsb-auth-btn-primary' %>
</div>
