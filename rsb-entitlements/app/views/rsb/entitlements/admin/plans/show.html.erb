<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold"><%= @plan.key %></h1>
  <a href="<%= rsb_admin_resource_path('plans') %>"
     class="inline-flex items-center gap-1 px-4 py-2 border border-rsb-border rounded-rsb text-sm hover:bg-rsb-bg transition-colors">Back</a>
</div>

<%# Actions bar %>
<div class="flex gap-2 mb-4">
  <% if @plan.archived_at.nil? %>
    <%= button_to t('rsb.entitlements.admin.plans.actions.archive'),
                  "#{rsb_admin_resource_show_path('plans', @plan.id)}/archive",
                  method: :post,
                  data: { confirm: t('rsb.entitlements.admin.plans.confirm.archive') },
                  class: 'inline-flex items-center px-4 py-2 border border-rsb-warning text-rsb-warning rounded-rsb text-sm font-medium hover:bg-rsb-warning-bg transition-colors' %>
  <% else %>
    <%= button_to t('rsb.entitlements.admin.plans.actions.unarchive'),
                  "#{rsb_admin_resource_show_path('plans', @plan.id)}/unarchive",
                  method: :post,
                  class: 'inline-flex items-center px-4 py-2 bg-rsb-primary text-rsb-primary-text rounded-rsb text-sm font-medium hover:bg-rsb-primary-hover transition-colors' %>
  <% end %>
  <a href="<%= rsb_admin_resource_edit_path('plans', @plan.id) %>"
     class="inline-flex items-center px-4 py-2 border border-rsb-border rounded-rsb text-sm hover:bg-rsb-bg transition-colors">
    Edit
  </a>
</div>

<%# Plan details %>
<div class="bg-rsb-card border border-rsb-border rounded-rsb-lg shadow-rsb-sm p-6 mb-4">
  <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-4 py-3 border-b border-rsb-border">
    <strong class="text-sm text-rsb-muted"><%= t('rsb.entitlements.admin.plans.fields.key') %></strong>
    <div class="text-sm font-mono"><%= @plan.key %></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-4 py-3 border-b border-rsb-border">
    <strong class="text-sm text-rsb-muted"><%= t('rsb.entitlements.admin.plans.fields.name') %></strong>
    <div class="text-sm"><%= @plan.name %></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-4 py-3 border-b border-rsb-border">
    <strong class="text-sm text-rsb-muted"><%= t('rsb.entitlements.admin.plans.fields.display_order') %></strong>
    <div class="text-sm"><%= @plan.display_order || 0 %></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-4 py-3 border-b border-rsb-border">
    <strong class="text-sm text-rsb-muted"><%= t('rsb.entitlements.admin.plans.fields.archived_at') %></strong>
    <div class="text-sm">
      <% if @plan.archived_at %>
        <span class="inline-block px-2 py-0.5 rounded-rsb text-xs font-medium bg-rsb-danger-bg text-rsb-danger-text">
          <%= @plan.archived_at.strftime('%B %d, %Y at %I:%M %p') %>
        </span>
      <% else %>
        <span class="text-rsb-muted">—</span>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-4 py-3 border-b border-rsb-border">
    <strong class="text-sm text-rsb-muted"><%= t('rsb.entitlements.admin.plans.fields.metadata') %></strong>
    <div>
      <% if @plan.metadata.blank? %>
        <span class="text-sm text-rsb-muted">—</span>
      <% else %>
        <pre class="text-xs font-mono bg-rsb-bg rounded-rsb p-3 overflow-x-auto border border-rsb-border"><%= JSON.pretty_generate(@plan.metadata) %></pre>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-4 py-3">
    <strong class="text-sm text-rsb-muted">Created</strong>
    <div class="text-sm"><%= @plan.created_at.strftime('%B %d, %Y at %I:%M %p') %></div>
  </div>
</div>

<%# Nested PlanFeature section %>
<%= render 'show_extra' %>
