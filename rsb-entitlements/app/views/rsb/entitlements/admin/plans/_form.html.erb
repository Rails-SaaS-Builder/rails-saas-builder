<%# Plan form partial. On new: full fields. On edit: key rendered read-only. %>
<%= form_with model: @plan,
              url: (@plan.new_record? ? rsb_admin_resource_path('plans') : rsb_admin_resource_show_path('plans', @plan.id)),
              method: (@plan.new_record? ? :post : :patch),
              local: true do |f| %>
  <% if @plan.errors.any? %>
    <div class="mb-4 p-4 bg-rsb-danger-bg border border-rsb-danger rounded-rsb-lg">
      <ul class="list-disc list-inside text-sm text-rsb-danger-text space-y-1">
        <% @plan.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <% if @plan.new_record? %>
      <div>
        <%= f.label :key, t('rsb.entitlements.admin.plans.fields.key'),
                    class: 'block text-sm font-medium text-rsb-text mb-1' %>
        <%= f.text_field :key, required: true,
                         class: 'w-full border border-rsb-border rounded-rsb px-3 py-2 text-sm',
                         placeholder: 'free, pro, enterprise' %>
      </div>
    <% else %>
      <div>
        <span class="block text-sm font-medium text-rsb-muted mb-1"><%= t('rsb.entitlements.admin.plans.fields.key') %></span>
        <span class="block text-sm font-mono px-3 py-2 bg-rsb-bg rounded-rsb border border-rsb-border text-rsb-muted"><%= @plan.key %></span>
      </div>
    <% end %>

    <div>
      <%= f.label :name, t('rsb.entitlements.admin.plans.fields.name'),
                  class: 'block text-sm font-medium text-rsb-text mb-1' %>
      <%= f.text_field :name, required: true,
                       class: 'w-full border border-rsb-border rounded-rsb px-3 py-2 text-sm' %>
    </div>

    <div>
      <%= f.label :display_order, t('rsb.entitlements.admin.plans.fields.display_order'),
                  class: 'block text-sm font-medium text-rsb-text mb-1' %>
      <%= f.number_field :display_order,
                         class: 'w-full border border-rsb-border rounded-rsb px-3 py-2 text-sm',
                         value: (@plan.display_order || 0) %>
    </div>

    <div>
      <%= f.label :metadata, t('rsb.entitlements.admin.plans.fields.metadata'),
                  class: 'block text-sm font-medium text-rsb-text mb-1' %>
      <textarea name="plan[metadata]" rows="6"
                class="w-full border border-rsb-border rounded-rsb px-3 py-2 text-sm font-mono"
                placeholder="{}"><%= JSON.pretty_generate(@plan.metadata || {}) %></textarea>
      <p class="text-xs text-rsb-muted mt-1"><%= t('rsb.entitlements.admin.plans.hints.metadata') %></p>
    </div>
  </div>

  <div class="mt-6 flex gap-3">
    <%= f.submit class: 'inline-flex items-center px-4 py-2 bg-rsb-primary text-rsb-primary-text rounded-rsb text-sm font-medium hover:bg-rsb-primary-hover transition-colors cursor-pointer' %>
    <a href="<%= rsb_admin_resource_path('plans') %>"
       class="inline-flex items-center px-4 py-2 border border-rsb-border rounded-rsb text-sm hover:bg-rsb-bg transition-colors">Cancel</a>
  </div>
<% end %>
